# Copy to .env.local and fill in. Every value is OPTIONAL:
# with none set, MoveMend runs on a mock AI analyzer + in-memory storage.

# --- AI (Claude Sonnet preferred) ---
# Without this, a deterministic mock analyzer is used.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=

# --- Database (Supabase Postgres) ---
# Set BOTH to persist cases/progress in Supabase. Otherwise storage is
# in-memory and resets when the server restarts.
# Run supabase/schema.sql first to create the tables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
